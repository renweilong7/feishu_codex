FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxx

# Comma-separated Feishu open_id allowlist. Leave empty to allow every user.
ALLOWED_USERS=

# Comma-separated chat_id allowlist. Leave empty to allow every chat.
ALLOWED_CHATS=

# Repo aliases exposed to Feishu commands.
# Format: alias=/absolute/path,another=/absolute/path
CODEX_REPOS=feishu_codex=/Users/renyi/code/python/feishu_codex
DEFAULT_REPO=feishu_codex

# Codex runtime options.
CODEX_BIN=codex
# Windows npm installs may need:
# CODEX_BIN=C:\Users\<you>\AppData\Roaming\npm\codex.cmd
CODEX_MODEL=
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL_POLICY=on-request
CODEX_SKIP_GIT_REPO_CHECK=true
CODEX_STREAM_UPDATE_INTERVAL=1.5
CODEX_MAX_CARD_LINES=32

# Server.
HOST=0.0.0.0
PORT=8000
